# SonarQube Exclusions
# Exclude files/directories from SonarQube analysis
# Syntax: Similar to .gitignore (one pattern per line)

# IDE & Editor directories
.idea/
.vscode/
.cursor/
.vs/
.fleet/
*.swp
*.swo
*~
.DS_Store

# Build outputs
dist/
build/
target/
out/

# Dependencies
node_modules/
vendor/
.venv/
venv/

# Test files (customize as needed)
*.test.js
*.spec.ts
__tests__/

# Static assets (images, fonts, etc.)
public/assets/
static/images/
*.svg
*.png
*.jpg
*.jpeg
*.gif
*.woff
*.woff2
*.ttf

# Generated/minified files
*.min.js
*.min.css
*.bundle.js
*.generated.js
*-generated.ts

# Configuration
*.config.js

# Documentation
docs/
*.md

# Add your project-specific exclusions below:
# example-dir/
# legacy-code/

